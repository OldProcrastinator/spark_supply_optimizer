# Copy this file to .env on each machine and adjust values.
#
# Multi-host Docker setup is intended for Linux hosts with Docker host networking.
# On Windows/macOS Docker Desktop, prefer local docker-compose.yml or direct host
# Spark scripts from README because Docker Desktop adds NAT between containers and LAN.

# Same image name on every machine.
SPARK_IMAGE=spark-supply-optimizer:dev

# Absolute path to this project checkout on the current machine.
# Linux example:
SPARK_PROJECT_ROOT=/home/user/spark_supply_optimizer

# MinIO is the S3-compatible object storage used for multi-host data/artifacts.
# Run it on one machine in the same LAN/VPN as Spark master/workers/driver.
MINIO_ENDPOINT=http://192.168.1.10:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=m5-data
MINIO_DATA_DIR_HOST=/home/user/minio-data

# Local folder with raw M5 CSV files on the machine that runs upload-data.
LOCAL_M5_DATA_DIR=/home/user/spark_supply_optimizer/data

# IP address of the machine where Spark master runs.
SPARK_MASTER_HOST=192.168.1.10
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080

# IP address of the machine where m5-spark driver is launched.
SPARK_DRIVER_HOST=192.168.1.20

# Per-worker resources.
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=4g
